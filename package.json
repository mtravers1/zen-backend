{
  "name": "zentavos-backend",
  "version": "2.6.0",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "run-build": "cd dist && node ./index.js",
    "start": "nodemon --inspect ./bin/www",
    "start:dev": "source ./scripts/version.sh && cross-env NODE_ENV=development nodemon -r dotenv/config --inspect ./bin/www",
    "start:staging": "./scripts/version.sh && cross-env NODE_ENV=staging nodemon -r dotenv/config --inspect ./bin/www",
    "start:prod": "./scripts/version.sh && cross-env NODE_ENV=production node -r dotenv/config ./bin/www",
    "mongodb": "docker-compose up",
    "build": "webpack --config webpack.config.js",
    "test": "./scripts/version.sh && cross-env NODE_ENV=test DOTENV_CONFIG_PATH=./.env.test NODE_OPTIONS=--experimental-vm-modules node -r dotenv/config ./node_modules/jest/bin/jest.js --runInBand",
    "test:vitest": "cross-env NODE_ENV=development node -r dotenv/config ./node_modules/.bin/vitest --run tests/cashflow-chart-synthetic.test.js",
    "migrate:encryption": "node -r dotenv/config scripts/migrate-encryption.js",
    "delete-user": "node -r dotenv/config scripts/delete-user.js",
    "delete-all-users": "node -r dotenv/config scripts/delete-all-users.js",
    "migrate:business-userid-normalize": "node -r dotenv/config scripts/migration/normalize-business-userid.js",
    "update-webhooks": "node -r dotenv/config scripts/update-plaid-webhooks.js",
    "delete-invalid-plaid-tokens": "node -r dotenv/config scripts/delete-invalid-plaid-tokens.js",
    "fix-transaction-dates": "node -r dotenv/config scripts/fix-transaction-dates.js",
    "delete-orphaned-pending-transactions": "node -r dotenv/config scripts/delete-orphaned-pending-transactions.js",
    "delete-duplicate-transactions": "node -r dotenv/config scripts/delete-duplicate-transactions.js"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@apple/app-store-server-library": "^1.5.0",
    "@google-cloud/kms": "^5.0.1",
    "@google-cloud/storage": "^7.15.2",
    "@sentry/node": "^10.32.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "debug": "^4.4.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "express-unless": "^2.1.3",
    "firebase-admin": "^13.0.1",
    "google-auth-library": "^10.4.0",
    "groq-sdk": "^0.22.0",
    "hbs": "^4.2.0",
    "http-errors": "^2.0.0",
    "jose": "^6.0.11",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.15.0",
    "mongodb-client-encryption": "^6.3.0",
    "mongoose": "^8.9.0",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.16",
    "ollama": "^0.5.15",
    "plaid": "^37.0.0",
    "prettier": "^3.7.3",
    "supertest": "^7.1.4",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "babel-jest": "^30.2.0",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^10.3.0",
    "node-loader": "^2.1.0",
    "nodemon": "^3.1.9",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  }
}
